# Optional standalone poller image. On Railway, run as a second service (same image/env as the app) or
# use HTTP tick + cron (see docs/sophia/deployment-railway.md). Legacy GCP used Cloud Run Job
# `sophia-ingestion-job-poller` (scripts/gcp/deploy-sophia-ingestion-poller-job.sh).
#
# Build: docker build -f Dockerfile.ingest-worker -t sophia-ingest-worker .
# Run:  docker run --env-file .env sophia-ingest-worker
#
# See docs/sophia/deployment-railway.md

FROM node:22-bookworm-slim

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@latest --activate

COPY . .

RUN pnpm install --frozen-lockfile --ignore-scripts

ENV NODE_ENV=production
# Recover durable-job child runs left `running` after deploy (no log/heartbeat); then auto-resume from checkpoint.
ENV INGEST_ORPHAN_LAST_OUTPUT_MS=120000
# Spread durable-job child launches to avoid synchronized 429s when multiple URLs exit LLM phases together.
ENV INGEST_JOB_LAUNCH_JITTER_MS=2000
# Align with app-spawned ingest children: temperature stage filter + smaller extraction batches.
ENV INGEST_OMIT_LLM_TEMPERATURE_STAGES=extraction,json_repair
ENV INGEST_EXTRACTION_BATCH_TOKEN_FRACTION=0.58

CMD ["pnpm", "exec", "tsx", "scripts/ingestion-job-poller.ts", "--interval", "5"]
