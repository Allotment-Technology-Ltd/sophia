    "ops:ingest-descartes-epistemology-extract-only": "tsx --env-file=.env scripts/ingest.ts data/sources/descartes-epistemology.txt --force-stage extracting --stop-after-extraction",
    "ops:ingest-descartes-epistemology-extract-only:fresh": "INGEST_FRESH_EXTRACTION=1 tsx --env-file=.env scripts/ingest.ts data/sources/descartes-epistemology.txt --force-stage extracting --stop-after-extraction",
    "ops:fetch-sep-disagreement-baseline": "tsx --env-file=.env scripts/fetch-source.ts https://plato.stanford.edu/entries/disagreement sep_entry",
    "ops:ingest-disagreement-extract-only": "tsx --env-file=.env scripts/ingest.ts data/sources/disagreement.txt --force-stage extracting --stop-after-extraction",
    "ops:ingest-disagreement-extract-only:fresh": "INGEST_FRESH_EXTRACTION=1 tsx --env-file=.env scripts/ingest.ts data/sources/disagreement.txt --force-stage extracting --stop-after-extraction",
    "ops:fetch-sep-hume-baseline": "tsx --env-file=.env scripts/fetch-source.ts https://plato.stanford.edu/entries/hume sep_entry",
    "ops:ingest-hume-extract-only": "tsx --env-file=.env scripts/ingest.ts data/sources/david-hume.txt --force-stage extracting --stop-after-extraction",
    "ops:ingest-hume-extract-only:fresh": "INGEST_FRESH_EXTRACTION=1 tsx --env-file=.env scripts/ingest.ts data/sources/david-hume.txt --force-stage extracting --stop-after-extraction",
    "ops:fetch-sep-spinoza-baseline": "tsx --env-file=.env scripts/fetch-source.ts https://plato.stanford.edu/entries/spinoza sep_entry",
    "ops:ingest-spinoza-extract-only": "tsx --env-file=.env scripts/ingest.ts data/sources/baruch-spinoza.txt --force-stage extracting --stop-after-extraction",
    "ops:ingest-spinoza-extract-only:fresh": "INGEST_FRESH_EXTRACTION=1 tsx --env-file=.env scripts/ingest.ts data/sources/baruch-spinoza.txt --force-stage extracting --stop-after-extraction",
    "ops:sample-extraction-remit-eval-jsonl": "tsx scripts/sample-extraction-remit-eval-jsonl.ts",
    "ops:audit-ingest-extraction-models-neon": "tsx scripts/audit-ingest-extraction-models-neon.ts",
    "ops:audit-ingest-cost-by-phase-neon": "tsx --env-file=.env scripts/audit-ingest-cost-by-phase-neon.ts",
    "ops:backfill-ingest-cost-neon": "tsx --env-file=.env scripts/backfill-ingest-cost-usd-snapshot-neon.ts",
    "ops:prune-neon-failed-ingest-runs": "tsx --env-file=.env scripts/prune-neon-failed-ingest-runs.ts",
