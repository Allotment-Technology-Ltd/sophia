    "ops:check-training-export-leakage": "tsx scripts/check-training-export-leakage.ts",
    "ops:audit-training-export-manifest": "tsx scripts/audit-training-export-manifest.ts",
    "ops:convert-training-jsonl-together-chat": "tsx scripts/convert-phase1-jsonl-to-together-chat.ts",
    "ops:phase2-step-a-together-packaging": "tsx --env-file=.env scripts/phase2-step-a-together-packaging.ts",
