    "ops:relabel-sidecar": "tsx scripts/relabel-programme.ts training-sidecar",
    "ops:relabel-neon-map": "tsx --env-file=.env scripts/relabel-programme.ts neon-map",
    "ops:relabel-sep-list": "tsx --env-file=.env scripts/relabel-programme.ts sep-reingest-list",
    "ops:backfill-source-training-exclusion": "tsx --env-file=.env scripts/backfill-source-training-exclusion.ts",
    "verify:prod-ingest": "bash scripts/verify-prod-ingest-isolated.sh",
    "byok:reencrypt-kms-to-local": "tsx --env-file=.env scripts/byok-reencrypt-kms-to-local.ts",
    "secrets:sync-gcp": "tsx scripts/sync-gcp-secret-manager-from-env.ts",
    "gcp:enable-apis": "bash scripts/gcp/enable-required-apis.sh",
    "gcp:ensure-wif-neon-access": "bash scripts/gcp/ensure-wif-neon-secret-access.sh",
    "gcp:deploy-ingestion-poller": "bash scripts/gcp/deploy-sophia-ingestion-poller-job.sh",
    "gcp:deploy-ingest-worker-service": "bash scripts/gcp/deploy-sophia-ingest-worker-service.sh",
    "gcp:setup-ingestion-poller-scheduler": "bash scripts/gcp/setup-ingestion-poller-scheduler.sh",
    "gcp:pause-cost-schedulers": "bash scripts/gcp/pause-cost-saving-schedulers.sh",
    "gcp:resume-cost-schedulers": "bash scripts/gcp/resume-cost-saving-schedulers.sh",
    "repomix:kb": "npx --yes repomix --config repomix.knowledge-base.config.json",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
