    "db:corpus-embedding-inventory": "tsx --env-file=.env scripts/corpus-embedding-inventory.ts",
    "db:stoa-schema": "tsx --env-file=.env scripts/setup-stoa-schema.ts",
    "neon:auth-env": "tsx --env-file=.env scripts/neon-auth-print-env.ts",
    "verify:neon-ingest-run": "tsx scripts/verify-neon-ingest-run.ts",
    "docs:verify-present": "bash scripts/verify-docs-present.sh",
