{
  "name": "sophia",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite": "vite dev",
    "dev:prod-db": "bash scripts/dev-prod-db.sh",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:surreal-writes": "tsx scripts/check-surreal-write-lint.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "monitor:wave": "tsx --env-file=.env scripts/monitor-wave.ts --once",
    "monitor:wave:watch": "tsx --env-file=.env scripts/monitor-wave.ts --interval-sec 120",
    "audit:gates": "tsx --env-file=.env scripts/phase1-closeout.ts --dry-run",
    "ingest:safe": "tsx --env-file=.env scripts/run-ingestion-safe.ts",
    "ingestion:job-poller": "tsx --env-file=.env scripts/ingestion-job-poller.ts",
    "sep:catalog": "tsx scripts/sep-catalog.ts",
    "ingest:wave1:retry": "tsx --env-file=.env scripts/ingest-batch.ts --wave 1 --retry --fail-fast --pre-scan",
    "ingest:unknown:resume": "tsx --env-file=.env scripts/ingest.ts data/sources/unknown-title.txt --stop-after-embedding",
    "ingest:nightly": "tsx --env-file=.env scripts/ingest-nightly-links.ts",
    "health": "curl -s --max-time 30 https://usesophia.app/api/health | jq .",
    "mcp:restormel": "pnpm dlx @restormel/mcp",
    "smoke:restormel": "bash scripts/smoke-test-restormel.sh",
    "smoke:restormel:mcp": "bash scripts/smoke-test-restormel-mcp.sh",
    "restormel:setup:status": "tsx --env-file=.env scripts/restormel/setup-status.ts",
    "restormel:route-steps": "tsx --env-file=.env scripts/restormel/route-steps.ts",
    "restormel:ingestion-bootstrap": "tsx --env-file=.env scripts/restormel/bootstrap-ingestion-routes.ts",
    "restormel:keys-catalog-diff": "tsx scripts/restormel/keys-catalog-diff.ts",
    "restormel:dogfood-issue": "bash scripts/restormel/create_dogfood_issue.sh",
    "migrate": "bash scripts/migrate-to-europe-west2.sh",
    "migrate:firestore-to-neon": "tsx scripts/migrate-firestore-to-neon.ts",
    "db:ping": "tsx scripts/db-ping.ts",
    "db:migrate": "tsx --env-file=.env scripts/neon-migrate.ts",
    "db:migrate:ci": "tsx scripts/neon-migrate.ts",
