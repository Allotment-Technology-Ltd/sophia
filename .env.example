# SOPHIA — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── AI API Keys ──────────────────────────────────────────────────────────────

# Anthropic Claude API (required — core reasoning engine)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini API (required — ingestion validation)
GOOGLE_AI_API_KEY=AIza-your-key-here

# Voyage AI (required — philosophical embeddings)
VOYAGE_API_KEY=pa-your-key-here

# ── Reasoning model routing (Depth-aware) ───────────────────────────────────

# Default reasoning model for standard/quick
GEMINI_REASONING_MODEL=gemini-2.0-flash

# Optional deep-mode model overrides (Vertex)
GEMINI_DEEP_REASONING_MODEL=gemini-2.5-pro
GEMINI_DEEP_ANALYSIS_MODEL=
GEMINI_DEEP_CRITIQUE_MODEL=
GEMINI_DEEP_SYNTHESIS_MODEL=
GEMINI_DEEP_VERIFICATION_MODEL=

# Enable deep model routing and choose provider for deep escalations
ENABLE_DEEP_MODEL_ROUTING=true
DEEP_MODEL_PROVIDER=vertex
# Comma-separated passes to escalate in deep mode
DEEP_MODEL_PASSES=critique,synthesis

# Optional Anthropic deep model route (only used when DEEP_MODEL_PROVIDER=anthropic)
CLAUDE_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_DEEP_MODEL=claude-sonnet-4-5-20250929

# ── SurrealDB ─────────────────────────────────────────────────────────────────

# Connection URL (ws:// for local, wss:// for remote)
SURREAL_URL=ws://localhost:8000/rpc

# Credentials
SURREAL_USER=root
SURREAL_PASS=your-password-here

# Namespace and database
SURREAL_NAMESPACE=sophia
SURREAL_DATABASE=sophia

# ── Analytics ─────────────────────────────────────────────────────────────────

# Google Analytics 4 measurement ID (optional — analytics disabled if unset)
# Create a GA4 property at analytics.google.com, then copy the measurement ID (G-XXXXXXXXXX)
PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog server-side analytics for API/developer telemetry (Zuplo + PostHog stack)
# Create a dedicated PostHog project for SOPHIA API inside your existing account.
POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_PROJECT_API_KEY=phc_your_project_api_key_here
POSTHOG_PROJECT_ID=123456

# Optional fallback: also mirror events to Firestore analytics collection
ENABLE_FIRESTORE_ANALYTICS_FALLBACK=false

# Optional: if set, /developer can link users to hosted Zuplo developer portal
PUBLIC_ZUPLO_DEVELOPER_PORTAL_URL=

# ── Feature flags ────────────────────────────────────────────────────────────

# Emit constitution_check in /api/analyse SSE stream (dogfooding rollout)
# false by default; enable gradually per docs/runbooks/constitution-dogfood-rollout.md
ENABLE_CONSTITUTION_IN_ANALYSE=false
# Depth enrichment flags (Epic 1-3 rollout)
ENABLE_DEPTH_ENRICHMENT=false
ENABLE_TARGETED_SOURCE_INTAKE=false
ENABLE_DOMAIN_OVERRIDE_UI=false
ENABLE_STAGING_PROMOTION=false
PUBLIC_ENABLE_DOMAIN_OVERRIDE_UI=true
ENABLE_LEARN_MODULE=true
PUBLIC_ENABLE_LEARN_MODULE=true
SCHOLAR_CREDIT_PRICE_CENTS=100
ENABLE_CONSTITUTION_PASS_DELTAS=true
ENABLE_REASONING_QUALITY_IN_ANALYSE=true

# Per-depth follow-up limits
# quick/standard defaults allow one follow-up (2 total questions), deep defaults to single query only.
PUBLIC_QUESTION_LIMIT_QUICK=2
PUBLIC_QUESTION_LIMIT_STANDARD=2
PUBLIC_QUESTION_LIMIT_DEEP=1

# ── Billing (Paddle) ──────────────────────────────────────────────────────────

# Paddle environment and auth
# Runtime selection:
# - default auto: sandbox in local/dev, production in prod runtime
# - optional override: PADDLE_RUNTIME=sandbox|production
PADDLE_RUNTIME=

# Runtime-specific credentials (recommended)
PADDLE_API_KEY_SANDBOX=
PADDLE_API_KEY_PRODUCTION=
PUBLIC_PADDLE_CLIENT_TOKEN_SANDBOX=
PUBLIC_PADDLE_CLIENT_TOKEN_PRODUCTION=
PUBLIC_PADDLE_CHECKOUT_LOCALE=en-GB
PUBLIC_PADDLE_CHECKOUT_THEME=dark
PUBLIC_PADDLE_CHECKOUT_VARIANT=one-page
PUBLIC_PADDLE_CHECKOUT_ALLOW_LOGOUT=false
PUBLIC_PADDLE_CHECKOUT_SHOW_ADD_TAX_ID=false

# Legacy fallback (optional, used if runtime-specific values are not set)
PADDLE_API_KEY=
PADDLE_API_VERSION=1
PADDLE_API_RETRY_MAX=10
PADDLE_API_LIST_PAUSE_MS=750
PADDLE_SKIP_DISCOVERY=false
PADDLE_WEBHOOK_SECRET_SANDBOX=
PADDLE_WEBHOOK_SECRET_PRODUCTION=
# Legacy fallback (optional)
PADDLE_WEBHOOK_SECRET=
PADDLE_ALLOW_UNSIGNED_WEBHOOKS=false

# App URL used for checkout success/cancel redirects and webhook destination defaults
PUBLIC_APP_URL=http://localhost:5173

# Checkout presentation defaults (redirect|overlay|inline)
PADDLE_CHECKOUT_MODE=redirect
# Optional locale override (e.g. en-GB, en-US)
PADDLE_CHECKOUT_LOCALE=
# Optional theme hint (light|dark)
PADDLE_CHECKOUT_THEME=

# Paddle price IDs (set by bootstrap script output)
# Recommended: keep sandbox + production IDs side-by-side.
PADDLE_PRICE_PRO_GBP_SANDBOX=
PADDLE_PRICE_PRO_USD_SANDBOX=
PADDLE_PRICE_PREMIUM_GBP_SANDBOX=
PADDLE_PRICE_PREMIUM_USD_SANDBOX=
PADDLE_PRICE_TOPUP_SMALL_GBP_SANDBOX=
PADDLE_PRICE_TOPUP_SMALL_USD_SANDBOX=
PADDLE_PRICE_TOPUP_LARGE_GBP_SANDBOX=
PADDLE_PRICE_TOPUP_LARGE_USD_SANDBOX=
PADDLE_PRICE_PRO_GBP_PRODUCTION=
PADDLE_PRICE_PRO_USD_PRODUCTION=
PADDLE_PRICE_PREMIUM_GBP_PRODUCTION=
PADDLE_PRICE_PREMIUM_USD_PRODUCTION=
PADDLE_PRICE_TOPUP_SMALL_GBP_PRODUCTION=
PADDLE_PRICE_TOPUP_SMALL_USD_PRODUCTION=
PADDLE_PRICE_TOPUP_LARGE_GBP_PRODUCTION=
PADDLE_PRICE_TOPUP_LARGE_USD_PRODUCTION=

# Legacy fallback IDs (optional)
PADDLE_PRICE_PRO_GBP=
PADDLE_PRICE_PRO_USD=
PADDLE_PRICE_PREMIUM_GBP=
PADDLE_PRICE_PREMIUM_USD=
PADDLE_PRICE_TOPUP_SMALL_GBP=
PADDLE_PRICE_TOPUP_SMALL_USD=
PADDLE_PRICE_TOPUP_LARGE_GBP=
PADDLE_PRICE_TOPUP_LARGE_USD=

# Optional webhook event override (comma-separated)
# PADDLE_WEBHOOK_EVENTS=transaction.completed,transaction.paid,subscription.created,subscription.updated,subscription.activated,subscription.trialing,subscription.past_due,subscription.canceled

# Optional tax category for generated products in bootstrap script
PADDLE_DEFAULT_TAX_CATEGORY=standard

# Bootstrap script defaults (minor units, e.g. pennies/cents)
PADDLE_SETUP_PRO_MONTHLY_GBP=699
PADDLE_SETUP_PRO_MONTHLY_USD=899
PADDLE_SETUP_PREMIUM_MONTHLY_GBP=1199
PADDLE_SETUP_PREMIUM_MONTHLY_USD=1499
PADDLE_SETUP_TOPUP_SMALL_GBP=500
PADDLE_SETUP_TOPUP_SMALL_USD=500
PADDLE_SETUP_TOPUP_LARGE_GBP=1500
PADDLE_SETUP_TOPUP_LARGE_USD=1500

# Billing feature flags
ENABLE_BILLING=true
ENABLE_BYOK_WALLET_CHARGING=false
BYOK_WALLET_SHADOW_MODE=true
ENABLE_INGEST_VISIBILITY_MODE=true

# BYOK wallet controls
BYOK_TOPUP_SMALL_CENTS=500
BYOK_TOPUP_LARGE_CENTS=1500
BYOK_WALLET_MIN_CENTS=1
