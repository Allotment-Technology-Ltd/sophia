# SOPHIA — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Required in every environment (Neon Auth + Postgres) ───────────────────
#
# 1) DATABASE_URL — Neon Postgres connection string (pooled URL recommended for serverless).
#    The server requires this when using the default SOPHIA_DATA_BACKEND=neon for `sophiaDocumentsDb`.
#
# 2) USE_NEON_AUTH=1 — Protected `/api/*` routes verify Bearer tokens as Neon Auth JWTs only.
#
# 3) NEON_AUTH_BASE_URL — Runtime (Node): branch auth base URL from Neon Console → Auth or
#    GET …/projects/{id}/branches/{id}/auth → `base_url` (ends with /…/auth).
#
# 4) VITE_NEON_AUTH_URL — Build-time / Vite: same value as NEON_AUTH_BASE_URL so the browser
#    auth client can sign in. Use `.env.local` for `pnpm dev`; CI sets it via Docker build args
#    (see .github/workflows/deploy.yml).
#
#    Production (Cloud Run): also set PUBLIC_NEON_AUTH_URL to the same value so the client can read
#    the auth base URL at runtime even if the Docker image was built without VITE_NEON_AUTH_URL.
# PUBLIC_NEON_AUTH_URL=
#
# Production (Cloud Run): DATABASE_URL from Secret Manager `neon-database-url`; GitHub secret
# NEON_AUTH_BASE_URL feeds both VITE_NEON_AUTH_URL (image build) and Cloud Run NEON_AUTH_BASE_URL;
# USE_NEON_AUTH=1 is set in the deploy workflow.

# ── AI API Keys ──────────────────────────────────────────────────────────────

# Anthropic Claude API (required — core reasoning engine)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini API (Google AI Studio) — primary platform path for catalog Gemini models (`vertex`
# provider slot). When set, the app uses @ai-sdk/google instead of Vertex ADC. Vertex ADC remains
# an optional fallback when this is unset but a GCP project id env is set (see GOOGLE_VERTEX_*).
GOOGLE_AI_API_KEY=AIza-your-key-here

# Voyage AI (required — philosophical embeddings)
VOYAGE_API_KEY=pa-your-key-here

# ── Restormel Keys integration ───────────────────────────────────────────────

# Control plane (server-side only; never expose keys in the browser or client bundles):
# - Gateway key (rk_…), RESTORMEL_PROJECT_ID, RESTORMEL_ENVIRONMENT_ID (e.g. production).
# - RESTORMEL_KEYS_BASE = dashboard API origin, e.g. https://restormel.dev/keys/dashboard
# Routes: create ingestion routes with workload=ingestion and stage=ingestion_extraction |
# ingestion_relations | ingestion_grouping | ingestion_validation | ingestion_json_repair
# (embedding: ingestion_embedding). Use a shared empty-stage route for fallback. Publish routes
# (version must equal publishedVersion). Dependency: @restormel/keys ≥0.2.11 from npm. Ingestion
# planning omits routeId on resolve when the RESTORMEL_INGEST_* overrides below are unset; Restormel
# selects by workload + stage (dedicated route first, then shared). List routes for admin UI;
# optional preflight: `restormelValidateRouteBinding` in `src/lib/server/restormel.ts`.
# Set RESTORMEL_INGEST_* only to pin a specific route UUID.
# If logs show [restormel] Resolve failed / routing_degraded: fix Keys first (publish + env), not UI fields.
RESTORMEL_GATEWAY_KEY=
RESTORMEL_PROJECT_ID=
RESTORMEL_ENVIRONMENT_ID=
RESTORMEL_KEYS_BASE=https://restormel.dev/keys/dashboard
RESTORMEL_BASE_URL=https://restormel.dev/keys/dashboard
# Project model index: send bindingKind "registry" for off-catalog / embedding rows (requires Keys migration 021).
# Set to 0 or unset only if the dashboard host is older than 021.
RESTORMEL_PROJECT_MODEL_REGISTRY_BINDINGS=1
RESTORMEL_ANALYSE_ROUTE_ID=
RESTORMEL_VERIFY_ROUTE_ID=
RESTORMEL_INGEST_ROUTE_ID=
RESTORMEL_INGEST_VALIDATION_ROUTE_ID=
RESTORMEL_INGEST_EXTRACTION_ROUTE_ID=
RESTORMEL_INGEST_RELATIONS_ROUTE_ID=
RESTORMEL_INGEST_GROUPING_ROUTE_ID=
RESTORMEL_INGEST_JSON_REPAIR_ROUTE_ID=
# Optional pin for remediation route (stage ingestion_remediation); defaults to catalog + canonical chain.
# RESTORMEL_INGEST_REMEDIATION_ROUTE_ID=
# Optional pin for embedding route (stage ingestion_embedding); should match EMBEDDING_PROVIDER + model.
# RESTORMEL_INGEST_EMBEDDING_ROUTE_ID=

# Optional — `pnpm restormel:ingestion-bootstrap apply` (scripts/restormel/bootstrap-ingestion-routes.ts)
# RESTORMEL_BOOTSTRAP_PRIMARY_PROVIDER=vertex
# RESTORMEL_BOOTSTRAP_PRIMARY_MODEL=gemini-3-flash-preview
# RESTORMEL_BOOTSTRAP_FALLBACK_PROVIDER=anthropic
# RESTORMEL_BOOTSTRAP_FALLBACK_MODEL=claude-haiku-4-5-20251001
# RESTORMEL_BOOTSTRAP_FALLBACK2_PROVIDER=vertex
# RESTORMEL_BOOTSTRAP_FALLBACK2_MODEL=gemini-3.1-pro-preview

# Optional full policy endpoint for local MCP usage.
RESTORMEL_EVALUATE_URL=

# Pro monthly Paddle prices (preferred keys).
PADDLE_PRICE_KEYS_PRO_MONTHLY_GBP=
PADDLE_PRICE_KEYS_PRO_MONTHLY_USD=
# Backward-compatible aliases still supported during migration:
# PADDLE_PRICE_PREMIUM_GBP=
# PADDLE_PRICE_PREMIUM_USD=

# Monthly platform-funded model-spend cap used by /api/analyse for non-BYOK runs.
# The remaining USD amount is also forwarded to Restormel resolve as constraints.maxCost.
PLATFORM_MONTHLY_SPEND_CAP_GBP=3.5
# GBP -> USD conversion used to derive maxCost for Restormel routing constraints.
PLATFORM_SPEND_USD_PER_GBP=1.27

# BYOK provider rollout gate (comma-separated provider IDs).
# Start conservatively and expand as providers are validated in production.
BYOK_ENABLED_PROVIDERS=vertex,anthropic

# If the Neon/Postgres store cannot read BYOK rows (e.g. missing DATABASE_URL), return an empty
# not_configured list instead of 503. `pnpm dev` does this automatically when the store errors.
# BYOK_PROVIDERS_FALLBACK_EMPTY=1

# ── Optional: GCP Application Default Credentials ────────────────────────────
# For Vertex / some Google APIs locally: `scripts/dev.mjs` can set GOOGLE_APPLICATION_CREDENTIALS
# from secrets/google-application-credentials.json or env. Not required for Neon Auth or `sophiaDocumentsDb`.
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-application-credentials.json

# BYOK encryption: runtime encrypt/decrypt uses local AES-256-GCM only.
# Legacy Cloud KMS rows must be re-encrypted with:
#   pnpm byok:reencrypt-kms-to-local --execute
# Optional legacy helper for migration only:
# BYOK_KMS_KEY_NAME=projects/.../locations/.../keyRings/.../cryptoKeys/...
# Keep this set in production to guarantee new encrypts never use Cloud KMS.
# BYOK_DISABLE_CLOUD_KMS_ENCRYPT=1
# Optional explicit local key (otherwise derived; see src/lib/server/byok/crypto.ts):
# BYOK_LOCAL_ENCRYPTION_KEY=your-long-random-secret

# Application owner (full quota/billing bypass for session auth + admin capabilities).
# Comma-separated lower-case emails — matched against the authenticated user's email from Neon Auth.
OWNER_EMAILS=
#
# Early access gate: when non-empty, only these emails may use the app after Google sign-in unless
# the user is an owner (OWNER_EMAILS / OWNER_UIDS / stored role). Others see /access-denied and can
# still use the public waitlist on /early-access. Empty = no email gate.
# ALLOWED_EMAILS=
#
# ADMIN_UIDS — Comma-separated Neon Auth user ids (JWT claim `sub`) allowed for admin API routes
# (e.g. Zuplo verification identity). Not the same as email; copy `sub` from a decoded JWT or Neon dashboard.
# Production: Secret Manager secret `admin-uids` → env ADMIN_UIDS (see deploy.yml).
# ADMIN_UIDS=
#
# OWNER_UIDS — Comma-separated Neon Auth `sub` values for operator BYOK bucket resolution
# (keys live on users/{firstSub}/byokProviders in sophia_documents). Replace any legacy Firebase UIDs
# with the same people's Neon `sub` after cutover.
# Role merge: `syncAuthenticatedUserRole` can merge owner/admin roles from older `users/*` docs that
# share the same normalized email — but BYOK documents are still keyed by id; update OWNER_UIDS so the
# first entry matches the Neon `sub` that should hold operator keys.
# Production: Secret Manager secret `owner-uids` → env OWNER_UIDS. ADMIN_UIDS alone does not set OWNER_UIDS.
# OWNER_UIDS=

# ── Neon Auth (runtime + client URL) ─────────────────────────────────────────
# USE_NEON_AUTH, NEON_AUTH_BASE_URL, and VITE_NEON_AUTH_URL are required — see checklist at top of file.
#
# USE_NEON_AUTH=1
# NEON_AUTH_BASE_URL=https://….neonauth….neon.tech/neondb/auth
# Same branch auth URL for Vite (local dev — often in .env.local):
# VITE_NEON_AUTH_URL=https://….neonauth….neon.tech/neondb/auth
#
# Or set JWKS/issuer explicitly (issuer = origin of the auth host, not the /auth path):
# NEON_AUTH_ISSUER=https://….
# NEON_AUTH_JWKS_URL=https://….neonauth….neon.tech/neondb/auth/.well-known/jwks.json
# NEON_AUTH_AUDIENCE=
#
# Print ready-to-paste server lines (needs NEON_API_KEY — Account → API keys):
# NEON_API_KEY=
# NEON_PROJECT_ID=
# NEON_BRANCH_ID=
# pnpm neon:auth-env
#
# CI: GitHub secret NEON_AUTH_BASE_URL → Docker build VITE_NEON_AUTH_URL + Cloud Run NEON_AUTH_BASE_URL + USE_NEON_AUTH=1

# ── Neon Postgres (durable ingest + sophia_documents / sophiaDocumentsDb) ──────
# Connection string from Neon (pooled recommended for serverless / Cloud Run).
# Enables: ingest_runs orchestration, staging tables, and (by default) Neon-backed `sophiaDocumentsDb`.
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#
# Real admin ingest (DATABASE_URL + INGEST_ORCHESTRATION_RUN_ID from the server, default --stop-before-store)
# can run stages 1–5 without a live SurrealDB; checkpoints go to Neon. Stage 6 / “Sync to SurrealDB” still needs SURREAL_*.
# Apply pending SQL in drizzle/ (e.g. source_text_snapshot on ingest_staging_meta) so workers can resume without data/sources on disk.
#
# When DATABASE_URL is set, `sophiaDocumentsDb` uses Postgres table `sophia_documents` unless SOPHIA_DATA_BACKEND=firestore
# (legacy only). Default is neon.
# One-time migration from old Firestore: `pnpm migrate:firestore-to-neon -- --execute`
# SOPHIA_DATA_BACKEND=neon

# ── SurrealDB ─────────────────────────────────────────────────────────────────
#
# Credentials are NOT committed — copy to `.env` / `.env.local`. Production uses Secret Manager
# (e.g. `surreal-db-pass`) and Cloud Run env injection; see `docs/operations/surrealdb-cloud-access.md`.
#
# Connection URL (any one approach):
# - **Option A — full URL:** set `SURREAL_URL` only (local `ws://…/rpc` or Cloud `wss://…/rpc`).
# - **Option B — split (common in `.env.local`):** leave `SURREAL_URL` unset and set:
#     `SURREAL_INSTANCE` + `SURREAL_HOSTNAME`  →  resolved as `wss://<INSTANCE>.<HOSTNAME>/rpc`
#     (same resolution as `src/lib/server/surrealEnv.ts`, `pnpm dev` materialisation, and `scripts/ingest.ts`).
# - If you paste `https://…` from a dashboard, it is normalised to `wss://…/rpc`.
SURREAL_URL=ws://localhost:8000/rpc
#
# Optional split vars (when `SURREAL_URL` is intentionally empty / omitted):
# SURREAL_INSTANCE=myinstance
# SURREAL_HOSTNAME=eu-west-1.aws.surrealdb.com

# Credentials (root + password from Surreal Cloud / self-hosted admin)
SURREAL_USER=root
SURREAL_PASS=your-password-here

# Namespace and database (must exist on the instance)
SURREAL_NAMESPACE=sophia
SURREAL_DATABASE=sophia

# Optional — access-record auth (same as scripts/ingest.ts signin fallbacks). Unset unless your Cloud instance uses it.
# SURREAL_ACCESS=

# Optional — Surreal CLI (`surreal export`, `surreal sql`) defaults to root-level signin (`--auth-level root`).
# Set this to match Surrealist: which column holds your user — Root / Namespace / Database.
# Example: system user `importer` only under Database (ns `main`, db `sophia`) → use database, not namespace.
# SURREAL_AUTH_LEVEL=database
# SURREAL_AUTH_LEVEL=namespace

# ── Admin ingest execution mode ────────────────────────────────────────────────
# Admin /expand ingestion UI is simulated by default.
# Set this to 1 to run real fetch-source + ingest.ts from localhost.
# ADMIN_INGEST_RUN_REAL=1
#
# Max concurrent real fetch+ingest child processes (clamped 1–20). Returns error when exceeded.
# Parallel real ingest child workers (default 2 when unset; raise e.g. 3–4 only if providers and host keep up).
# ADMIN_INGEST_MAX_CONCURRENT=2
# When 1, use Neon ingest_concurrency_gate so multiple app instances share one global cap (requires db:migrate).
# INGEST_GLOBAL_CONCURRENCY_GATE=0
#
# Neon durable ingest — cut `ingest_run_logs` chatter (each line was INSERT + activity bump; see `ingestRuns.ts`):
# full (default) | minimal (orchestrator lines + filtered child stdout) | off (no log rows; snapshot_json still writes).
# INGEST_NEON_LOG_PERSISTENCE=minimal
# Debounce `lastOutputAt` bumps in Neon after log lines (ms, clamped 200–120000; default 1500).
# INGEST_NEON_ACTIVITY_DEBOUNCE_MS=1500
#
# Durable multi-URL jobs: max starts per URL before terminal error (default 2). Failed items re-queue to pending automatically.
# INGEST_JOB_ITEM_MAX_ATTEMPTS=2
# Random delay 0..N ms between spawning the next child run from a job tick (spread load; optional).
# INGEST_JOB_LAUNCH_JITTER_MS=0
# Optional: cap concurrent ingest.ts Stage 4 embedding calls across runs (Neon ingest_phase_gate; 0 = off).
# INGEST_PHASE_EMBED_MAX_CONCURRENT=0
#
# Stage-6 parallel Surreal passage CREATE chunks in scripts/ingest.ts (default 8, max 12).
# INGEST_PASSAGE_INSERT_CONCURRENCY=8
#
# Vertex embedding: delay between batches in ms (default 80; lower = higher throughput, watch quotas).
# VERTEX_EMBED_BATCH_DELAY_MS=80
#
# Vertex embedding: instances per request (max 250). Smaller values = more API calls but more frequent
# disk checkpoints during Stage 4 (*-partial.json). Default 250.
# VERTEX_EMBED_BATCH_SIZE=250
#
# Aliases for worker ergonomics (mapped to VERTEX_EMBED_* before Stage 4).
# INGEST_EMBED_BATCH_SIZE=250
# INGEST_EMBED_BATCH_DELAY_MS=80
#
# Validation: default `cli` follows --validate; `off` skips; `full`/`sampled` force validation (sampled uses INGEST_VALIDATION_SAMPLE_RATE).
# INGEST_VALIDATION_MODE=cli
# INGEST_VALIDATION_SAMPLE_RATE=1.0
#
# Optional raw HTML cache for scripts/fetch-source.ts (keyed by canonical URL hash; reduces flaky HTTP on retry).
# FETCH_SOURCE_CACHE=0
# FETCH_SOURCE_CACHE_TTL_HOURS=24
#
# Neon serverless pool (optional cap; helps multi-worker hosts).
# NEON_POOL_MAX=10
#
# Stage 6 Surreal: parallel claim CREATEs per chunk (default 8; lower if Surreal saturates).
# INGEST_CLAIM_INSERT_CONCURRENCY=8
# Library batch-inserter (if used): cap concurrent claim CREATEs per flush.
# SURREAL_CLAIM_INSERT_CONCURRENCY=12
#
# SEP / benchmark preset discipline (see docs/operations/ingestion-sep-preset-discipline.md).
# INGEST_PRESET_DISCIPLINE=off
# INGEST_PRESET_PROFILE=sep-benchmark-2026-04
#
# Post-store: queue low faithfulness claims for human review (needs_review); ties to /api/admin/quarantine/queue.
# INGEST_POST_STORE_LOW_VALIDATION_REVIEW_THRESHOLD=
# INGEST_POST_STORE_LOW_VALIDATION_SAMPLE_RATE=1
# INGEST_POST_STORE_FLAG_VERIFICATION_LOW_VALIDATION=0
#
# Durable multi-URL jobs (Neon): optional Restormel health check before job create.
# INGEST_JOB_PREFLIGHT=0
# Re-queue job items whose error string is unknown (not retry/permanent). Default off.
# INGEST_JOB_REQUEUE_UNKNOWN=0
#
# Stuck child detection (ingestion job tick). 0 = disabled.
# INGEST_JOB_ITEM_MAX_WALL_MS=0
# INGEST_JOB_ITEM_STALE_MS=0
#
# Re-ingest when Surreal ingestion_log is already "complete": child `ingest.ts` normally skips.
# Durable jobs pass this via job JSON workerDefaults `{ "forceReingest": true }` (preferred).
# INGEST_FORCE_REINGEST=1
#
# Idle watchdog (Neon): terminalize in-flight ingest_runs with no worker activity after idle (default 5m in code).
# Activity = max(`last_output_at`, `worker_heartbeat_at`) when set; see migration `drizzle/0013_ingest_worker_heartbeat.sql`.
# Runs from `tickAllRunningIngestionJobs` (admin jobs UI + `scripts/ingestion-job-poller.ts`). Set to 0 to disable.
# INGEST_WATCHDOG_IDLE_MS=0
# Optional: max runs processed per sweep (default 25).
# INGEST_WATCHDOG_BATCH=25
# When 1, job items linked to a watchdog-terminated run go back to pending (clears child_run_id) instead of error.
# INGEST_WATCHDOG_REQUEUE=0
# Optional per-phase idle thresholds (ms, ≥60000). Keys: extracting, relating, grouping, embedding, validating, remediating, storing.
# INGEST_WATCHDOG_PHASE_IDLE_JSON={"extracting":480000,"storing":600000}
# Optional: multiply average completed-phase wall from last `[INGEST_TIMING]` line to derive a threshold for the current phase (when JSON unset).
# INGEST_WATCHDOG_PHASE_BASELINE_MULT=2.5
#
# Ingest worker: periodic heartbeat + Neon `worker_heartbeat_at` bump during long `generateText` (orchestrated runs only).
# Unset + `INGEST_ORCHESTRATION_RUN_ID` set → default 45000 ms. Set `INGEST_TELEMETRY_HEARTBEAT_MS=0` to disable. Min 10000, max 120000.
# INGEST_TELEMETRY_HEARTBEAT_MS=0
#
# Dead letter: optional auto-replay for `retryable_exhausted` items after DLQ cooldown (≥60s). 0 = off.
# INGEST_DLQ_AUTO_REPLAY_DELAY_MS=0
#
# Launch throttle backoff (concurrent worker cap); base and cap in ms.
# INGEST_JOB_LAUNCH_BACKOFF_BASE_MS=2000
# INGEST_JOB_LAUNCH_BACKOFF_MAX_MS=600000
#
# Surreal store: optional SHA-256 of source body on `source`; enforce abort on hash mismatch.
# INGEST_STORE_RECORD_TEXT_HASH=1
# INGEST_STORE_ENFORCE_TEXT_HASH=0
#
# Merge in-progress ingest run into Firestore ingestion_run_reports at most this often (ms) while status is running.
# Default 120000 (2 minutes). Min 30000, max 1 hour.
# ADMIN_INGEST_REPORT_PERSIST_INTERVAL_MS=120000
#
# Neon-backed ingest queue (Phase 6):
# - when DATABASE_URL + ADMIN_INGEST_RUN_REAL=1 are set, runs are enqueued with status=queued
# - worker poller claims and executes them durably
# INGEST_QUEUE_ENABLED=true
# LINK_QUEUE_PROMOTION_BATCH_SIZE=5
# ENABLE_SELF_SERVE_INGESTION_QUEUE=true
#
# Ingest worker provider keys: operator BYOK comes from sophia_documents (`OWNER_UIDS` → users/{sub}/byokProviders).
# For local dev without prod keys in sophia_documents, standard env vars (ANTHROPIC_API_KEY, OPENAI_API_KEY,
# VOYAGE_API_KEY, … — same names as in this file) are merged into the worker when the document store has no
# value for that provider. To always prefer `.env` / `.env.local` over the store (e.g. prod BYOK doc
# exists but keys only work on GCP), set:
# INGEST_PREFER_LOCAL_PROVIDER_KEYS=1
#
# Optional: auto-open a gcloud SSH tunnel for private SurrealDB targets when running `pnpm dev`.
# Useful when production SURREAL_URL uses a private VPC IP.
# DEV_SURREAL_TUNNEL=true
# DEV_SURREAL_TUNNEL_INSTANCE=sophia-db
# DEV_SURREAL_TUNNEL_ZONE=europe-west2-b
# DEV_SURREAL_TUNNEL_PROJECT=sophia-488807
# DEV_SURREAL_TUNNEL_LOCAL_PORT=8800
#
# For live writes from localhost:
# - set SURREAL_URL / SURREAL_USER / SURREAL_PASS to your live Surreal target
# - ensure DATABASE_URL and model API keys are set for the worker

# ── Analytics ─────────────────────────────────────────────────────────────────

# Google Analytics 4 measurement ID (optional — analytics disabled if unset)
# Create a GA4 property at analytics.google.com, then copy the measurement ID (G-XXXXXXXXXX)
PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog server-side analytics for API/developer telemetry (Zuplo + PostHog stack)
# Create a dedicated PostHog project for SOPHIA API inside your existing account.
POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_PROJECT_API_KEY=phc_your_project_api_key_here
POSTHOG_PROJECT_ID=123456

# Optional fallback: also mirror events to Firestore analytics collection
ENABLE_FIRESTORE_ANALYTICS_FALLBACK=false

# Optional: if set, /developer can link users to hosted Zuplo developer portal
PUBLIC_ZUPLO_DEVELOPER_PORTAL_URL=

# ── Feature flags ────────────────────────────────────────────────────────────

# Emit constitution_check in /api/analyse SSE stream (dogfooding rollout)
# false by default; enable gradually per docs/runbooks/constitution-dogfood-rollout.md
ENABLE_CONSTITUTION_IN_ANALYSE=false
# Depth enrichment flags (Epic 1-3 rollout)
ENABLE_DEPTH_ENRICHMENT=false
ENABLE_TARGETED_SOURCE_INTAKE=false
ENABLE_DOMAIN_OVERRIDE_UI=false
ENABLE_STAGING_PROMOTION=false
# Ignored by the app UI: Reasoning Focus is always shown on /app.
PUBLIC_ENABLE_DOMAIN_OVERRIDE_UI=true
ENABLE_CONSTITUTION_PASS_DELTAS=true
ENABLE_REASONING_QUALITY_IN_ANALYSE=true

# Per-depth follow-up limits
# quick/standard defaults allow one follow-up (2 total questions), deep defaults to single query only.
PUBLIC_QUESTION_LIMIT_QUICK=2
PUBLIC_QUESTION_LIMIT_STANDARD=2
PUBLIC_QUESTION_LIMIT_DEEP=1

# ── Ingestion hardening ─────────────────────────────────────────────────────
# Embeddings: pick one provider for production (768-dim vertex vs 1024-dim voyage). Changing this may require
# Surreal vector index migration + re-embed. See docs/operations/ingestion-embedding-lock.md
# EMBEDDING_PROVIDER=vertex
# EMBEDDING_PROVIDER=voyage
#
# scripts/ingest.ts: default skips the global 768-vs-1024 Surreal probe so ingest works during migration without Cloud Run env.
# Set to 0/false/no after the corpus is uniformly re-embedded to enforce matching dimensions again.
# INGEST_EMBEDDING_IGNORE_LEGACY_CORPUS_DIM=0
#
# Admin “Issue resolution” re-embed jobs (Neon tables reembed_jobs / reembed_job_events). Apply drizzle/0012_reembed_jobs.sql via pnpm db:migrate.
# Advance work with scripts/ingestion-job-poller.ts or POST /api/admin/reembed/jobs/[id]/tick (owner). See docs/operations/reembed-corpus-contract.md
#
# Admin ingest: worker/advisor defaults live in the UI (Pipeline setup → Worker and advisor defaults), saved in the browser.
# Use these env vars only for CLI runs of scripts/ingest.ts or when you need a process-wide default without the admin UI.
INGEST_PROVIDER=auto
#
# Fine-tune / training lineage (scripts/ingest.ts): default **strict** — only allowed providers may run
# extraction, relations, grouping, remediation, json_repair (validation may still use Vertex/OpenAI).
# Production workers need MISTRAL_API_KEY (or BYOK) and Mistral-capable Restormel routes for those stages.
# INGEST_FINETUNE_LABELER_STRICT=1
# Comma-separated allowlist when strict (default: mistral only).
# INGEST_FINETUNE_LABELER_ALLOWED_PROVIDERS=mistral
# Local experiments without Mistral routing (not for production training export):
# INGEST_FINETUNE_LABELER_STRICT=0
#
# Admin ingest worker (no explicit model pins) injects catalog-ordered fallback chains from Model availability + Restormel catalog.
# CLI only: base64url JSON map of stages → [{provider,modelId},…] — same shape as buildIngestCatalogRoutingJson().
# INGEST_CATALOG_ROUTING_JSON_B64=
# Optional CLI fallbacks (same names the worker reads). Admin runs merge UI + Advanced batch overrides into the child env.
# INGESTION_ADVISOR_MODE=off
# INGESTION_ADVISOR_AUTO_APPLY=preset,validation
# VALIDATION_BATCH_TARGET_TOKENS=70000
# INGEST_EXTRACTION_MAX_TOKENS_PER_SECTION=5000
# Parallel single-passage extraction batches (default 2; set 1 if you see 429s).
# INGEST_EXTRACTION_CONCURRENCY=2

# Optional: apply drizzle/*.sql to Neon in order (tracks schema_migrations). Requires DATABASE_URL.
# pnpm db:migrate

# Ingestion: soft per-provider TPM throttle (rolling window). Unset = disabled.
# INGEST_PROVIDER_TPM_BUDGET=openai:800000,anthropic:400000,vertex:2000000
# INGEST_PROVIDER_TPM_WINDOW_MS=60000

# When 1, successful LLM calls increment success_count in ingest_llm_model_health (off by default).
# INGEST_LLM_HEALTH_RECORD_SUCCESS=0

# Self-healing ingestion (optional): reactive recovery agent after inner retries (transient errors only).
# INGEST_RECOVERY_AGENT=0
# INGEST_RECOVERY_AGENT_MAX_SLEEP_MS=120000
# INGEST_RECOVERY_AGENT_TIMEOUT_MS=45000
# Soft circuit: after N failures on same stage+model in one ingest process, skip that tier (0 = disabled).
# INGEST_CIRCUIT_FAILURE_THRESHOLD=0

# Post-validation remediation (Stage 5b — between validation and store when --validate is on).
# Default: on unless INGEST_REMEDIATION=0. Repairs low-faithfulness / quarantined claims; re-embeds; optional revalidate.
# INGEST_REMEDIATION=1
# INGEST_REMEDIATION_FAITHFULNESS_MIN=80
# INGEST_REMEDIATION_VALIDITY_MIN=80
# INGEST_REMEDIATION_MAX_CLAIMS=24
# INGEST_REMEDIATION_REVALIDATE=0
# INGEST_REMEDIATION_FORCE_RELATIONS_RERUN=0
# INGEST_REMEDIATION_RERUN_SHARE=0.12
# INGEST_REMEDIATION_POLICY_JSON=
# Per-stage timeout override (ms): INGEST_STAGE_REMEDIATION_TIMEOUT_MS=

# Relations: default 12000 target; capIngestBatchTargetForPlan + TPM split shrink batches on rate errors.
# RELATIONS_BATCH_TARGET_TOKENS=12000

# ── SurrealDB claim vector index (HNSW preferred, MTREE fallback) ───────────
# SURREAL_VECTOR_INDEX_MODE=auto|hnsw|mtree
# SURREAL_VECTOR_INDEX_CONCURRENTLY=0
# Fail setup-schema if vector index cannot be created: SURREAL_REQUIRE_VECTOR_INDEX=1
# CI / deploy gate: SURREAL_VECTOR_AUDIT_STRICT=1 tsx scripts/audit-surreal-vector-index.ts

# Dense retrieval KNN ef (Surreal <|k,ef|>); legacy single-arg fallback if server rejects two-arg form.
# RETRIEVAL_KNN_EF=64
# RELATIONS_BATCH_OVERLAP_CLAIMS=6
# INGEST_FAIL_ON_GROUPING_POSITION_COLLAPSE=true
