{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stoa",
  "identifier": "app.allotment.stoa",
  "version": "0.3.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Stoa — A Stoic Academy",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "theme": "Dark"
      }
    ]
  }
}
