FROM node:20-alpine

WORKDIR /app

# Install dependencies with npm install (more flexible than npm ci)
COPY package.json package-lock.json ./
RUN npm install --legacy-peer-deps 2>&1 | tail -20 || echo "Install completed"

# Copy application code
COPY . .

# Default wave number (override via Cloud Run --set-env-vars WAVE_NUM=N)
ENV WAVE_NUM=1

# Shell form so ${WAVE_NUM} gets expanded at runtime
CMD npx tsx scripts/ingest-batch.ts --wave ${WAVE_NUM} --fast --retry
