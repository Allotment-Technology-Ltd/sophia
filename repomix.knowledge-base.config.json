{
  "$schema": "https://repomix.dev/schemas/v0.3/schema.json",
  "input": {
    "maxFileSize": 45000
  },
  "output": {
    "headerText": "Sophia KB-oriented pack: curated docs only (see repomix include list), omits route +page.svelte, lib/components/**/*.svelte, large files, tests, static assets; compress + strip comments. Full repo: npx repomix (default, no --config).",
    "filePath": "repomix-knowledge-base.xml",
    "style": "xml",
    "compress": true,
    "removeComments": true,
    "removeEmptyLines": false,
    "truncateBase64": true,
    "directoryStructure": true,
    "fileSummary": true,
    "parsableStyle": false
  },
  "include": [
    "src/**/*.{ts,js,svelte,css}",
    "scripts/**/*.{ts,mjs,js}",
    "packages/**/*.ts",
    ".github/workflows/deploy.yml",
    "apps/**/*.{json,md}",
    "README.md",
    "docs/README.md",
    "docs/sophia/README.md",
    "docs/sophia/architecture.md",
    "docs/sophia/roadmap.md",
    "docs/sophia/current-state.md",
    "docs/stoa_game/README.md",
    "docs/restormel/README.md",
    "docs/operations/ingestion-credits-and-workers.md",
    "package.json",
    "pnpm-workspace.yaml",
    "svelte.config.js",
    "vite.config.js",
    "tailwind.config.js",
    "postcss.config.js",
    "tsconfig.json",
    "jsconfig.json",
    "drizzle.config.ts",
    "Dockerfile",
    ".github/workflows/**/*.yml",
    ".cursor/rules/**/*.mdc"
  ],
  "ignore": {
    "customPatterns": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/e2e/**",
      "**/__tests__/**",
      "docs/archive/**",
      "static/**",
      "repomix-output.xml",
      "repomix-knowledge-base.xml",
      "**/node_modules/**",
      "**/dist/**",
      "**/.svelte-kit/**",
      "**/build/**",
      "src/routes/**/+page.svelte",
      "src/lib/components/**/*.svelte"
    ]
  }
}
